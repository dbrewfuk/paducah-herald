# ==============================================================================
# Twill Magazine Starter — environment template
# Copy to .env and fill in the blanks before running `php artisan key:generate`.
# ==============================================================================

APP_NAME="Magazine"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com

# Localization — set to 'it', 'en', 'fr', etc.
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ------------------------------------------------------------------------------
# Site identity (read by config/site.php)
# ------------------------------------------------------------------------------
SITE_NAME="Magazine"
SITE_TAGLINE="A new publication."
SITE_WORDMARK_MAIN="Magazine"
SITE_WORDMARK_SUB=""
SITE_ASSET_VERSION=1

# ------------------------------------------------------------------------------
# Database (MySQL on a LEMP droplet — swap to sqlite for local dev if desired)
# ------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=twill
DB_USERNAME=twill
DB_PASSWORD=

# ------------------------------------------------------------------------------
# Sessions, queue, cache — all DB-backed by default (no Redis required)
# ------------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ------------------------------------------------------------------------------
# Mail (optional — defaults to log driver so nothing is sent until configured)
# ------------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
